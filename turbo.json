{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**", ".next/**", "build/**", "cdk.out/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "format": {},
    "format:ci": {},
    "lint": {},
    "lint:ci": {},
    "typecheck": {},
    "license": {},
    "security": {},
    "check": {
      "dependsOn": ["lint", "format", "typecheck"]
    },
    "check:ci": {
      "dependsOn": ["lint:ci", "format:ci", "typecheck", "license", "security"]
    }
  }
}
